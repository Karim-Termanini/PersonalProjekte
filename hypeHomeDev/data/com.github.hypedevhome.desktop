[Desktop Entry]
Type=Application
Name=HypeDevHome
GenericName=Developer Dashboard
Comment=Developer dashboard and tool manager for Linux
Exec=hypedevhome
Icon=com.github.hypedevhome
Terminal=false
Categories=Development;Utility;
StartupNotify=true
