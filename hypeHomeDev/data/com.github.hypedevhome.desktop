X-Flatpak-RenamedFrom=hypedevhome.desktop;

# Keywords for application menu
Keywords=developer;dashboard;tools;terminal;git;docker;flatpak;

# Additional metadata
MimeType=
Actions=

# Only show in GNOME
OnlyShowIn=GNOME;Unity;XFCE;Pantheon;

# Internationalization
Name[en]=HypeDevHome
Comment[en]=Developer dashboard and tool manager for Linux
GenericName[en]=Developer Dashboard