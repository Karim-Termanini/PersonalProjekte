<component type="desktop-application">
  <id>com.github.hypedevhome</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>HypeDevHome</name>
  <summary>Developer dashboard for Linux</summary>
  <description>
    <p>
      HypeDevHome is a comprehensive developer dashboard and tool manager for Linux.
      It provides a unified interface for managing development environments, monitoring
      system resources, and accessing common developer tools.
    </p>
    <p>Key features:</p>
    <ul>
      <li>Unified developer dashboard with system monitoring</li>
      <li>Docker and container management interface</li>
      <li>Git repository browser and quick actions</li>
      <li>Flatpak application management</li>
      <li>Terminal multiplexer with split panes</li>
      <li>Extension system for custom tools and integrations</li>
      <li>Project templates and quick starters</li>
    </ul>
  </description>
  
