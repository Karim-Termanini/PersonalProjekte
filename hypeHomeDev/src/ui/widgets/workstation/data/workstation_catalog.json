{
  "schema_version": 2,
  "placeholders": {
    "GO_VERSION": "1.23.4",
    "GO_ARCH": "linux-amd64",
    "NVM_VERSION": "0.40.1",
    "USER_NAME": "Your Name",
    "USER_EMAIL": "you@example.com"
  },
  "categories": [
    {
      "id": "dev",
      "label": "Dev",
      "groups": [
        {
          "title": "Python",
          "description": "uv is the modern fast installer; pipx for CLI tools; pyenv for version management.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install uv (recommended)",
              "command": "curl -LsSf https://astral.sh/uv/install.sh | sh",
              "check_cmd": "uv --version"
            },
            {
              "type": "runnable",
              "title": "Install Python via uv",
              "command": "uv python install 3.12"
            },
            {
              "type": "runnable",
              "title": "Install pipx",
              "distro_install": "pipx",
              "check_cmd": "pipx --version"
            },
            {
              "type": "runnable",
              "title": "Install pyenv",
              "command": "curl https://pyenv.run | bash",
              "check_cmd": "pyenv --version"
            },
            {
              "type": "runnable",
              "title": "Install system Python",
              "distro_install": "python3 python3-pip python3-venv",
              "check_cmd": "python3 --version"
            }
          ]
        },
        {
          "title": "Rust",
          "description": "rustup manages Rust toolchains, cargo is the build system.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install rustup + stable",
              "command": "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y",
              "check_cmd": "rustc --version"
            },
            {
              "type": "runnable",
              "title": "Update Rust",
              "command": "rustup update"
            },
            {
              "type": "runnable",
              "title": "Install nightly",
              "command": "rustup toolchain install nightly"
            }
          ]
        },
        {
          "title": "Go",
          "description": "Install from the official tarball or your distro package manager.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install Go (distro)",
              "distro_install": "golang",
              "check_cmd": "go version"
            },
            {
              "type": "runnable",
              "title": "Install Go (official)",
              "command": "curl -fsSL https://go.dev/dl/go{{GO_VERSION}}.{{GO_ARCH}}.tar.gz | sudo tar -C /usr/local -xzf -"
            }
          ]
        },
        {
          "title": "Node.js",
          "description": "nvm for version management; fnm as a faster alternative.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install nvm",
              "command": "curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v{{NVM_VERSION}}/install.sh | bash",
              "check_cmd": "nvm --version"
            },
            {
              "type": "runnable",
              "title": "Install Node LTS (via nvm)",
              "command": "nvm install --lts"
            },
            {
              "type": "runnable",
              "title": "Install fnm (fast alt)",
              "command": "curl -fsSL https://fnm.vercel.app/install | bash",
              "check_cmd": "fnm --version"
            },
            {
              "type": "runnable",
              "title": "Install Node (distro)",
              "distro_install": "nodejs npm",
              "check_cmd": "node --version"
            }
          ]
        },
        {
          "title": "Java",
          "description": "SDKMAN manages JDKs and tools (Gradle, Maven, etc.).",
          "rows": [
            {
              "type": "runnable",
              "title": "Install SDKMAN",
              "command": "curl -s \"https://get.sdkman.io\" | bash",
              "check_cmd": "sdk version"
            },
            {
              "type": "runnable",
              "title": "Install Java 21 (SDKMAN)",
              "command": "sdk install java 21-open"
            },
            {
              "type": "runnable",
              "title": "Install OpenJDK (distro)",
              "distro_packages": {
                "dnf": "java-21-openjdk-devel",
                "apt": "openjdk-21-jdk",
                "pacman": "jdk-openjdk",
                "zypper": "java-21-openjdk-devel",
                "apk": "openjdk21",
                "unknown": "openjdk-21-jdk"
              },
              "check_cmd": "java --version"
            },
            {
              "type": "runnable",
              "title": "Install Maven",
              "distro_install": "maven",
              "check_cmd": "mvn --version"
            },
            {
              "type": "runnable",
              "title": "Install Gradle (SDKMAN)",
              "command": "sdk install gradle"
            }
          ]
        },
        {
          "title": "C / C++",
          "description": "Compiler toolchain + build systems.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install C/C++ toolchain",
              "distro_packages": {
                "dnf": "gcc gcc-c++ make cmake gdb",
                "apt": "build-essential cmake gdb",
                "pacman": "base-devel cmake gdb",
                "zypper": "gcc gcc-c++ make cmake gdb",
                "apk": "build-base cmake gdb",
                "unknown": "gcc g++ make cmake gdb"
              },
              "check_cmd": "gcc --version"
            },
            {
              "type": "runnable",
              "title": "Install Clang",
              "distro_install": "clang",
              "check_cmd": "clang --version"
            }
          ]
        },
        {
          "title": ".NET / C#",
          "description": "Official .NET SDK for building C# / F# / VB.NET applications.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install .NET SDK",
              "distro_install": "dotnet-sdk-8.0",
              "check_cmd": "dotnet --version"
            }
          ]
        },
        {
          "title": "PHP",
          "description": "PHP runtime + Composer package manager.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install PHP",
              "distro_install": "php php-cli php-mbstring",
              "check_cmd": "php --version"
            },
            {
              "type": "runnable",
              "title": "Install Composer",
              "command": "curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer",
              "check_cmd": "composer --version"
            }
          ]
        }
      ],
      "removal_groups": [
        {
          "title": "Python",
          "description": "Remove Python version managers and tools.",
          "rows": [
            {
              "type": "runnable",
              "title": "Uninstall uv",
              "command": "rm -rf ~/.cargo/bin/uv ~/.cargo/bin/uvx"
            },
            {
              "type": "runnable",
              "title": "Uninstall pyenv",
              "command": "rm -rf ~/.pyenv"
            },
            {
              "type": "runnable",
              "title": "Uninstall pipx",
              "command": "pipx uninstall-all && pip uninstall pipx"
            },
            {
              "type": "runnable",
              "title": "Remove pip cache",
              "command": "pip cache purge"
            },
            {
              "type": "runnable",
              "title": "Remove uv cache",
              "command": "uv cache clean"
            }
          ]
        },
        {
          "title": "Rust",
          "description": "Remove rustup, toolchains, and cargo caches.",
          "rows": [
            {
              "type": "runnable",
              "title": "Remove a toolchain",
              "command": "rustup toolchain uninstall stable"
            },
            {
              "type": "runnable",
              "title": "Uninstall rustup entirely",
              "command": "rustup self uninstall"
            },
            {
              "type": "runnable",
              "title": "Clean cargo cache",
              "command": "cargo cache -a 2>/dev/null || rm -rf ~/.cargo/registry ~/.cargo/git"
            }
          ]
        },
        {
          "title": "Go",
          "description": "Remove Go installation and caches.",
          "rows": [
            {
              "type": "runnable",
              "title": "Remove Go (official)",
              "command": "sudo rm -rf /usr/local/go"
            },
            {
              "type": "runnable",
              "title": "Remove Go (distro)",
              "distro_remove": "golang"
            },
            {
              "type": "runnable",
              "title": "Clean module cache",
              "command": "go clean -modcache"
            },
            {
              "type": "runnable",
              "title": "Clean build cache",
              "command": "go clean -cache"
            }
          ]
        },
        {
          "title": "Node.js",
          "description": "Remove Node version managers and npm cache.",
          "rows": [
            {
              "type": "runnable",
              "title": "Uninstall Node version (nvm)",
              "command": "nvm uninstall VERSION"
            },
            {
              "type": "runnable",
              "title": "Uninstall nvm",
              "command": "rm -rf ~/.nvm"
            },
            {
              "type": "runnable",
              "title": "Uninstall fnm",
              "command": "rm -rf ~/.local/share/fnm ~/.fnm"
            },
            {
              "type": "runnable",
              "title": "Remove Node (distro)",
              "distro_remove": "nodejs npm"
            },
            {
              "type": "runnable",
              "title": "Clean npm cache",
              "command": "npm cache clean --force"
            }
          ]
        },
        {
          "title": "Java / SDKMAN",
          "description": "Remove JDKs and SDKMAN.",
          "rows": [
            {
              "type": "runnable",
              "title": "Uninstall Java (SDKMAN)",
              "command": "sdk uninstall java VERSION"
            },
            {
              "type": "runnable",
              "title": "Uninstall SDKMAN",
              "command": "rm -rf ~/.sdkman"
            },
            {
              "type": "runnable",
              "title": "Remove OpenJDK (distro)",
              "distro_remove": "java-21-openjdk-devel"
            },
            {
              "type": "runnable",
              "title": "Remove Maven (distro)",
              "distro_remove": "maven"
            }
          ]
        },
        {
          "title": "C / C++",
          "description": "Remove compilers and build tools.",
          "rows": [
            {
              "type": "runnable",
              "title": "Remove C/C++ toolchain",
              "distro_remove_packages": {
                "dnf": "gcc gcc-c++ cmake gdb",
                "apt": "build-essential cmake gdb",
                "pacman": "base-devel cmake gdb",
                "zypper": "gcc gcc-c++ cmake gdb",
                "apk": "build-base cmake gdb",
                "unknown": "gcc g++ cmake gdb"
              }
            },
            {
              "type": "runnable",
              "title": "Remove Clang",
              "distro_remove": "clang"
            }
          ]
        },
        {
          "title": ".NET",
          "description": "Remove .NET SDK.",
          "rows": [
            {
              "type": "runnable",
              "title": "Remove .NET SDK",
              "distro_remove": "dotnet-sdk-8.0"
            }
          ]
        },
        {
          "title": "PHP",
          "description": "Remove PHP and Composer.",
          "rows": [
            {
              "type": "runnable",
              "title": "Remove PHP",
              "distro_remove": "php php-cli php-mbstring"
            },
            {
              "type": "runnable",
              "title": "Remove Composer",
              "command": "sudo rm -f /usr/local/bin/composer"
            }
          ]
        }
      ]
    },
    {
      "id": "editors",
      "label": "Editors",
      "groups": [
        {
          "title": "Visual Studio Code",
          "description": "Microsoft's editor. Flatpak or official repo.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install (Flatpak)",
              "flatpak": "com.visualstudio.Code",
              "check_cmd": "flatpak info com.visualstudio.Code"
            },
            {
              "type": "runnable",
              "title": "Install (RPM repo — Fedora)",
              "pm_only": "dnf",
              "command": "sudo rpm --import https://packages.microsoft.com/keys/microsoft.asc && printf '[code]\\nname=Visual Studio Code\\nbaseurl=https://packages.microsoft.com/yumrepos/vscode\\nenabled=1\\ngpgcheck=1\\ngpgkey=https://packages.microsoft.com/keys/microsoft.asc\\n' | sudo tee /etc/yum.repos.d/vscode.repo > /dev/null && sudo dnf install -y code"
            }
          ]
        },
        {
          "title": "Cursor",
          "description": "AI-native code editor. AppImage download.",
          "rows": [
            {
              "type": "runnable",
              "title": "Download Cursor AppImage",
              "command": "curl -fsSL https://www.cursor.com/api/download?platform=linux-x64 -o \"$HOME/Downloads/cursor.appimage\" && chmod +x \"$HOME/Downloads/cursor.appimage\"",
              "check_cmd": "which cursor"
            }
          ]
        },
        {
          "title": "Zed",
          "description": "High-performance GPU-accelerated editor written in Rust.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install Zed",
              "command": "curl -f https://zed.dev/install.sh | sh",
              "check_cmd": "which zed"
            }
          ]
        },
        {
          "title": "Sublime Text",
          "description": "Fast, lightweight text editor.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install (Flatpak)",
              "flatpak": "com.sublimetext.three",
              "check_cmd": "flatpak info com.sublimetext.three"
            },
            {
              "type": "runnable",
              "title": "Install (distro)",
              "distro_install": "sublime-text",
              "check_cmd": "which subl"
            }
          ]
        },
        {
          "title": "Neovim",
          "description": "Hyperextensible terminal-based editor.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install Neovim",
              "distro_install": "neovim",
              "check_cmd": "nvim --version"
            },
            {
              "type": "runnable",
              "title": "Install (AppImage latest)",
              "command": "curl -fsSLo \"$HOME/Downloads/nvim.appimage\" https://github.com/neovim/neovim/releases/latest/download/nvim.appimage && chmod +x \"$HOME/Downloads/nvim.appimage\""
            }
          ]
        },
        {
          "title": "Emacs",
          "description": "The extensible, self-documenting editor.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install Emacs",
              "distro_install": "emacs",
              "check_cmd": "emacs --version"
            }
          ]
        },
        {
          "title": "JetBrains Toolbox",
          "description": "Manage all JetBrains IDEs (IntelliJ, PyCharm, WebStorm, etc.).",
          "rows": [
            {
              "type": "runnable",
              "title": "Install (Flatpak)",
              "flatpak": "com.jetbrains.Toolbox",
              "check_cmd": "flatpak info com.jetbrains.Toolbox"
            }
          ]
        }
      ],
      "removal_groups": [
        {
          "title": "VS Code",
          "description": "Remove Visual Studio Code and its configuration.",
          "rows": [
            {
              "type": "runnable",
              "title": "Uninstall (Flatpak)",
              "flatpak_remove": "com.visualstudio.Code"
            },
            {
              "type": "runnable",
              "title": "Uninstall (distro)",
              "distro_remove": "code"
            },
            {
              "type": "runnable",
              "title": "Remove config",
              "command": "rm -rf ~/.config/Code ~/.vscode"
            }
          ]
        },
        {
          "title": "Cursor",
