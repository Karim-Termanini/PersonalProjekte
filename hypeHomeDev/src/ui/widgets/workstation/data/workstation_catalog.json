              "title": "Uninstall (distro)",
              "distro_remove": "emacs"
            },
            {
              "type": "runnable",
              "title": "Remove config",
              "command": "rm -rf ~/.emacs.d ~/.config/emacs"
            }
          ]
        },
        {
          "title": "JetBrains Toolbox",
          "description": "Remove JetBrains Toolbox and all managed IDEs.",
          "rows": [
            {
              "type": "runnable",
              "title": "Uninstall (Flatpak)",
              "flatpak_remove": "com.jetbrains.Toolbox"
            },
            {
              "type": "runnable",
              "title": "Remove Toolbox + IDEs",
              "command": "rm -rf ~/.local/share/JetBrains ~/.config/JetBrains"
            }
          ]
