          "rows": [
            {
              "type": "runnable",
              "title": "Remove AppImage",
              "command": "rm -f ~/Downloads/cursor.appimage"
            },
            {
              "type": "runnable",
              "title": "Remove config",
              "command": "rm -rf ~/.config/Cursor ~/.cursor"
            }
          ]
        },
        {
          "title": "Zed",
          "description": "Remove Zed editor.",
          "rows": [
            {
              "type": "runnable",
              "title": "Uninstall Zed",
              "command": "rm -rf ~/.local/bin/zed ~/.local/share/zed"
            },
            {
              "type": "runnable",
              "title": "Remove config",
              "command": "rm -rf ~/.config/zed"
            }
          ]
        },
        {
          "title": "Sublime Text",
          "description": "Remove Sublime Text.",
          "rows": [
            {
              "type": "runnable",
              "title": "Uninstall (Flatpak)",
              "flatpak_remove": "com.sublimetext.three"
            },
            {
              "type": "runnable",
              "title": "Uninstall (distro)",
              "distro_remove": "sublime-text"
            },
            {
              "type": "runnable",
              "title": "Remove config",
              "command": "rm -rf ~/.config/sublime-text"
            }
          ]
        },
        {
          "title": "Neovim",
          "description": "Remove Neovim and its configuration.",
          "rows": [
            {
              "type": "runnable",
              "title": "Uninstall (distro)",
              "distro_remove": "neovim"
            },
            {
              "type": "runnable",
              "title": "Remove AppImage",
