      ]
    },
    {
      "id": "terminals",
      "label": "Terminals",
      "groups": [
        {
          "title": "Alacritty",
          "description": "GPU-accelerated terminal emulator.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install Alacritty",
              "distro_install": "alacritty",
              "check_cmd": "alacritty --version"
            }
          ]
        },
        {
          "title": "Ghostty",
          "description": "Fast, native terminal by Mitchell Hashimoto.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install (Flatpak)",
              "flatpak": "com.mitchellh.ghostty",
              "check_cmd": "flatpak info com.mitchellh.ghostty"
            },
            {
              "type": "runnable",
              "title": "Build from source",
              "command": "git clone https://github.com/ghostty-org/ghostty && cd ghostty && zig build -Doptimize=ReleaseFast"
            }
          ]
        },
        {
          "title": "Kitty",
          "description": "Feature-rich GPU-based terminal.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install Kitty",
              "distro_install": "kitty",
              "check_cmd": "kitty --version"
            },
            {
              "type": "runnable",
              "title": "Install (official script)",
              "command": "curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin"
            }
          ]
        },
        {
          "title": "WezTerm",
          "description": "GPU-accelerated terminal with Lua configuration.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install (Flatpak)",
              "flatpak": "org.wezfurlong.wezterm",
              "check_cmd": "flatpak info org.wezfurlong.wezterm"
            },
            {
              "type": "runnable",
              "title": "Install (distro)",
              "distro_install": "wezterm",
              "check_cmd": "wezterm --version"
