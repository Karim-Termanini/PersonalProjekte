    {
      "id": "cleanup",
      "label": "Cleanup",
      "groups": [
        {
          "title": "Distro and Flatpak (copy templates)",
          "description": "Replace PACKAGENAME / APP_ID / SNAPNAME before running. For searchable removal, use Install → Packages.",
          "rows": [
            {
              "type": "copy",
              "pm_only": "dnf",
              "title": "Remove one package",
              "distro_remove": "PACKAGENAME"
            },
            {
              "type": "copy",
              "pm_only": "dnf",
              "title": "List installed (verbose)",
              "command": "dnf list --installed"
            },
            {
              "type": "copy",
              "pm_only": "dnf",
              "title": "Search name in installed RPMs",
              "command": "rpm -qa | grep -i partial_name"
            },
            {
              "type": "copy",
              "pm_only": "apt",
              "title": "Remove one package",
              "distro_remove": "PACKAGENAME"
            },
            {
              "type": "copy",
              "pm_only": "apt",
              "title": "List installed packages",
              "command": "dpkg -l | less"
            },
            {
              "type": "copy",
              "pm_only": "apt",
              "title": "Search installed",
              "command": "dpkg -l | grep -i partial_name"
            },
            {
              "type": "copy",
              "pm_only": "pacman",
              "title": "Remove one package",
              "distro_remove": "PACKAGENAME"
            },
            {
              "type": "copy",
              "pm_only": "pacman",
              "title": "List installed",
              "command": "pacman -Q"
            },
            {
              "type": "copy",
              "pm_only": "pacman",
              "title": "Search installed",
              "command": "pacman -Qs partial_name"
            },
            {
              "type": "copy",
              "pm_only": "zypper",
              "title": "Remove one package",
              "distro_remove": "PACKAGENAME"
            },
            {
              "type": "copy",
              "pm_only": "zypper",
              "title": "List installed",
              "command": "zypper se -i"
            },
            {
              "type": "copy",
              "pm_only": "apk",
              "title": "Remove one package",
              "distro_remove": "PACKAGENAME"
            },
            {
              "type": "copy",
              "pm_only": "apk",
              "title": "List installed",
              "command": "apk list -I"
            },
            {
              "type": "copy",
              "pm_only": "unknown",
              "title": "Remove package (edit manager)",
              "distro_remove": "PACKAGENAME"
            },
            {
              "type": "copy",
              "title": "Uninstall Flatpak app",
              "command": "flatpak uninstall --user APP_ID"
            },
            {
              "type": "copy",
              "title": "Uninstall Flatpak + delete data",
              "command": "flatpak uninstall --user --delete-data APP_ID"
            },
            {
              "type": "copy",
              "title": "Remove snap",
              "command": "sudo snap remove SNAPNAME"
            },
            {
              "type": "copy",
              "title": "Remove snap + purge data",
              "command": "sudo snap remove --purge SNAPNAME"
            }
          ]
        },
        {
          "title": "Lists you can run here",
          "description": "No placeholders; output may open in a terminal if sudo is needed.",
          "rows": [
            {
              "type": "runnable",
              "pm_only": "dnf",
              "title": "Preview installed RPM names (first 200)",
              "command": "rpm -qa | sort | head -200"
            },
            {
              "type": "runnable",
              "pm_only": "apt",
              "title": "Preview installed packages (first 200)",
              "command": "dpkg -l | head -200"
            },
            {
              "type": "runnable",
              "pm_only": "pacman",
              "title": "Preview installed packages (first 200)",
              "command": "pacman -Q | head -200"
            },
            {
              "type": "runnable",
              "pm_only": "zypper",
              "title": "List installed (first 200 lines)",
              "command": "zypper se -i | head -200"
            },
            {
              "type": "runnable",
              "pm_only": "apk",
              "title": "List installed (first 200 lines)",
              "command": "apk list -I | head -200"
            },
            {
              "type": "runnable",
              "title": "List Flatpak apps (user)",
              "command": "flatpak list --app --user"
            },
            {
              "type": "runnable",
              "title": "List Snap apps",
              "command": "snap list 2>/dev/null || echo 'snap not installed'"
            }
          ]
        },
        {
          "title": "Flatpak cleanup",
          "description": "Removes unused runtimes (not apps). May ask for permission in a terminal.",
          "rows": [
            {
              "type": "runnable",
              "title": "Remove unused Flatpak runtimes",
              "command": "flatpak uninstall --user --unused"
            }
          ]
        },
        {
          "title": "System cache",
          "description": "Clean package manager and system caches.",
          "rows": [
            {
              "type": "runnable",
              "pm_only": "dnf",
              "title": "Clean dnf cache",
              "command": "sudo dnf clean all"
            },
            {
              "type": "runnable",
              "pm_only": "dnf",
              "title": "Remove old kernels",
              "command": "sudo dnf remove --oldinstallonly"
            },
            {
              "type": "runnable",
              "pm_only": "apt",
              "title": "Clean apt cache",
              "command": "sudo apt clean"
            },
            {
              "type": "runnable",
              "pm_only": "apt",
              "title": "Autoremove orphans",
              "command": "sudo apt autoremove -y"
            },
            {
              "type": "runnable",
              "pm_only": "apt",
              "title": "Purge removed configs",
              "command": "sudo dpkg --purge $(dpkg -l | awk '/^rc/ {print $2}')"
            },
            {
              "type": "runnable",
              "pm_only": "pacman",
              "title": "Clean pacman cache",
              "command": "sudo pacman -Sc --noconfirm"
            },
            {
              "type": "runnable",
              "pm_only": "pacman",
              "title": "Remove orphans",
              "command": "sudo pacman -Rns $(pacman -Qdtq) --noconfirm"
            },
            {
              "type": "runnable",
              "pm_only": "unknown",
              "title": "Clean package cache",
              "command": "echo 'Run your distro cache clean command'"
            },
            {
              "type": "runnable",
              "title": "Clean Flatpak unused",
              "command": "flatpak uninstall --user --unused"
            }
          ]
        },
        {
          "title": "User cache",
          "description": "Free space from user-level caches (safe to remove).",
          "rows": [
            {
              "type": "runnable",
              "title": "Check ~/.cache size",
              "command": "du -sh ~/.cache"
            },
            {
              "type": "runnable",
              "title": "Clean thumbnail cache",
              "command": "rm -rf ~/.cache/thumbnails"
            },
            {
              "type": "runnable",
              "title": "Clean pip cache",
              "command": "pip cache purge"
            },
            {
              "type": "runnable",
              "title": "Clean npm cache",
              "command": "npm cache clean --force"
            },
            {
              "type": "runnable",
              "title": "Clean uv cache",
              "command": "uv cache clean"
            },
            {
              "type": "runnable",
              "title": "Clean cargo cache",
              "command": "rm -rf ~/.cargo/registry ~/.cargo/git"
            },
            {
              "type": "runnable",
              "title": "Clean Go cache",
              "command": "go clean -cache -modcache"
            }
          ]
        },
        {
          "title": "Logs",
          "description": "Clean old system logs to free disk space.",
          "rows": [
            {
              "type": "runnable",
              "title": "Check journal size",
              "command": "journalctl --disk-usage"
            },
            {
              "type": "runnable",
              "title": "Keep last 7 days",
              "command": "sudo journalctl --vacuum-time=7d"
            },
            {
              "type": "runnable",
              "title": "Keep max 500M",
              "command": "sudo journalctl --vacuum-size=500M"
            }
          ]
        },
        {
          "title": "Disk usage",
          "description": "Find what is taking space.",
          "rows": [
            {
              "type": "runnable",
              "title": "Disk usage overview",
              "command": "df -h /"
            },
            {
              "type": "runnable",
              "title": "Largest dirs in home",
              "command": "du -sh ~/* ~/.* 2>/dev/null | sort -rh | head -20"
            },
            {
              "type": "runnable",
              "title": "Largest dirs system-wide",
              "command": "sudo du -sh /* 2>/dev/null | sort -rh | head -15"
            }
          ]
        }
      ]
    },
    {
      "id": "config",
      "label": "Config",
      "groups": [
        {
          "id": "git",
          "title": "Git Identity",
          "description": "Configure your global Git personal settings.",
          "rows": [
            { "title": "Set Name", "command": "git config --global user.name \"{{USER_NAME}}\"" },
            { "title": "Set Email", "command": "git config --global user.email \"{{USER_EMAIL}}\"" },
            { "title": "Set Default Branch (main)", "command": "git config --global init.defaultBranch main" },
            { "title": "Set Default Editor (vim)", "command": "git config --global core.editor vim" },
            { "title": "Set Default Editor (vscode)", "command": "git config --global core.editor \"code --wait\"" },
            { "title": "List all config", "command": "git config --list" }
          ]
        },
        {
          "id": "ssh",
          "title": "SSH Identity",
          "description": "Generate and manage SSH keys for GitHub/GitLab authentication.",
          "rows": [
            { "title": "Generate Ed25519 key", "command": "ssh-keygen -t ed25519 -C \"{{USER_EMAIL}}\"" },
            { "title": "Generate RSA 4096 key", "command": "ssh-keygen -t rsa -b 4096 -C \"{{USER_EMAIL}}\"" },
            { "type": "copy", "title": "Copy PubKey (Ed25519)", "command": "cat ~/.ssh/id_ed25519.pub" },
            { "type": "copy", "title": "Copy PubKey (RSA)", "command": "cat ~/.ssh/id_rsa.pub" },
            { "title": "Test GitHub connectivity", "command": "ssh -T git@github.com" }
          ]
        },
        {
          "id": "system",
          "title": "System Tuning",
          "description": "Distro-specific performance and mirror optimizations.",
          "rows": [
            {
              "title": "Optimize DNF (Fedora)",
              "pm_only": "dnf",
              "command": "sudo sed -i '/^max_parallel_downloads=/d' /etc/dnf/dnf.conf && echo 'max_parallel_downloads=10' | sudo tee -a /etc/dnf/dnf.conf && sudo sed -i '/^fastestmirror=/d' /etc/dnf/dnf.conf && echo 'fastestmirror=True' | sudo tee -a /etc/dnf/dnf.conf && echo 'DNF optimized.'"
            },
            {
              "title": "Update Mirrorlist (Arch)",
              "pm_only": "pacman",
              "command": "sudo pacman -Sy reflector --noconfirm && sudo reflector --latest 20 --protocol https --sort rate --save /etc/pacman.d/mirrorlist && echo 'Mirrors updated.'"
            },
            {
              "title": "Check Update Sources (Ubuntu)",
              "pm_only": "apt",
              "command": "cat /etc/apt/sources.list"
            }
          ]
        },
        {
          "id": "dotfiles",
          "title": "Dotfiles and Aliases",
          "description": "Manage common development aliases and environment variables.",
          "rows": [
            {
              "title": "Add common aliases",
              "command": "alias ll='ls -lah'\nalias gs='git status'\nalias dc='docker compose'\nalias gp='git push'\n",
              "tag": "~/.zshrc:aliases"
            },
            {
              "title": "Create Dev folder",
              "command": "mkdir -p ~/dev && echo '~/dev folder ensured.'"
            }
          ]
        }
      ]
    }
  ]
}
