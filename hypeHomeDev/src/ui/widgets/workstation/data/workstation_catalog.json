          ]
        },
        {
          "title": "tmux",
          "description": "Terminal multiplexer.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install tmux",
              "distro_install": "tmux",
              "check_cmd": "tmux -V"
            }
          ]
        },
        {
          "title": "Starship",
          "description": "Cross-shell prompt.",
          "rows": [
            {
              "type": "runnable",
              "title": "Install Starship",
              "command": "curl -sS https://starship.rs/install.sh | sh",
              "check_cmd": "starship --version"
            }
          ]
        }
      ]
    },
    {
      "id": "alacritty_cfg",
      "label": "Alacritty Config",
      "groups": [
        {
          "title": "General",
          "description": "Config: ~/.config/alacritty/alacritty.toml",
          "rows": [
            {
              "title": "Create config dir",
              "command": "mkdir -p ~/.config/alacritty"
            },
            {
              "type": "terminal",
              "title": "Open config in vim",
              "command": "vim ~/.config/alacritty/alacritty.toml"
            }
          ]
        },
        {
          "title": "Font",
          "description": "Set font family and size.",
          "rows": [
            {
              "title": "Set font (JetBrains Mono 13)",
              "command": "[font]\nsize = 13.0\n\n[font.normal]\nfamily = \"JetBrains Mono\"\nstyle = \"Regular\"\n",
              "tag": "~/.config/alacritty/alacritty.toml:font"
            }
          ]
        },
        {
          "title": "Themes",
          "rows": [
            {
              "title": "Import themes repo",
              "command": "git clone https://github.com/alacritty/alacritty-theme ~/.config/alacritty/themes"
            },
            {
              "title": "Set Dracula theme",
              "command": "import = [\"~/.config/alacritty/themes/themes/dracula.toml\"]\n",
              "tag": "~/.config/alacritty/alacritty.toml:theme"
            }
          ]
        }
      ],
      "removal_groups": [
        {
          "title": "Alacritty",
          "description": "Remove Alacritty and its config.",
          "rows": [
            {
              "type": "runnable",
              "title": "Uninstall (distro)",
              "distro_remove": "alacritty"
            },
            {
              "type": "runnable",
              "title": "Remove config",
              "command": "rm -rf ~/.config/alacritty"
            }
          ]
        }
      ]
    },
    {
      "id": "ghostty_cfg",
      "label": "Ghostty Config",
      "groups": [
        {
          "title": "General",
          "description": "Config: ~/.config/ghostty/config",
          "rows": [
            {
              "title": "Create config dir",
              "command": "mkdir -p ~/.config/ghostty"
            },
            {
              "type": "terminal",
              "title": "Open config in vim",
              "command": "vim ~/.config/ghostty/config"
            }
          ]
        },
        {
          "title": "Appearance",
          "rows": [
            {
              "title": "Set font (JetBrains Mono 13)",
              "command": "font-family = JetBrains Mono\nfont-size = 13\n",
              "tag": "~/.config/ghostty/config:font"
            },
            {
              "title": "Set Dracula theme",
              "command": "theme = Dracula\n",
              "tag": "~/.config/ghostty/config:theme"
            },
            {
              "title": "Opacity + Padding",
              "command": "background-opacity = 0.92\nwindow-padding-x = 8\nwindow-padding-y = 8\n",
              "tag": "~/.config/ghostty/config:window"
            }
          ]
        }
      ],
      "removal_groups": [
        {
          "title": "Ghostty",
