    {
      "id": "tmux_cfg",
      "label": "tmux Config",
      "groups": [
        {
          "title": "General",
          "description": "Config: ~/.tmux.conf",
          "rows": [
            {
              "type": "terminal",
              "title": "Open config in vim",
              "command": "vim ~/.tmux.conf"
            },
            {
              "title": "Reload config",
              "command": "tmux source-file ~/.tmux.conf"
            }
          ]
        },
        {
          "title": "Settings",
          "rows": [
            {
              "title": "Set prefix to Ctrl+A",
              "command": "unbind C-b\nset -g prefix C-a\nbind C-a send-prefix\n",
              "tag": "~/.tmux.conf:prefix"
            },
            {
              "title": "Enable mouse mode",
              "command": "set -g mouse on\n",
              "tag": "~/.tmux.conf:mouse"
            },
            {
              "title": "256 color support",
              "command": "set -g default-terminal \"tmux-256color\"\nset -ag terminal-overrides \",xterm-256color:RGB\"\n",
              "tag": "~/.tmux.conf:colors"
            }
          ]
        },
        {
          "title": "Plugins (TPM)",
          "rows": [
            {
              "title": "Install TPM",
              "command": "git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm"
            },
            {
              "title": "Add TPM to config",
              "command": "set -g @plugin \"tmux-plugins/tpm\"\nset -g @plugin \"tmux-plugins/tmux-sensible\"\nrun \"~/.tmux/plugins/tpm/tpm\"\n",
              "tag": "~/.tmux.conf:tpm"
            }
          ]
        }
      ],
      "removal_groups": [
        {
          "title": "tmux",
          "description": "Remove tmux, config, and plugins.",
          "rows": [
            {
              "type": "runnable",
              "title": "Uninstall (distro)",
              "distro_remove": "tmux"
            },
            {
              "type": "runnable",
              "title": "Remove config",
              "command": "rm -f ~/.tmux.conf"
            },
            {
              "type": "runnable",
              "title": "Remove plugins (TPM)",
              "command": "rm -rf ~/.tmux"
            }
          ]
        }
      ]
    },
    {
      "id": "zsh_cfg",
      "label": "Zsh Config",
      "groups": [
        {
          "title": "General",
          "description": "Config: ~/.zshrc",
          "rows": [
            {
              "type": "terminal",
              "title": "Open config in vim",
              "command": "vim ~/.zshrc"
            },
            {
              "title": "Reload config",
              "command": "source ~/.zshrc"
            }
          ]
        },
        {
          "title": "Plugins &amp; Themes",
          "rows": [
            {
              "title": "Set agnoster theme",
              "command": "sed -i 's/ZSH_THEME=.*/ZSH_THEME=\"agnoster\"/' ~/.zshrc"
