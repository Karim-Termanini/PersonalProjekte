        {
          "id": "create_run",
          "title": "Docker CLI",
          "description": "Create & run",
          "items": [
            {
              "type": "code",
              "code": "docker create [options] IMAGE\n  -a, --attach\n  -i, --interactive\n  -t, --tty\n  -p, --publish 5000:5000\n  -v, --volume pwd:/app\n  -e, --env NAME=value"
            },
            {
              "type": "text",
              "text": "See docker create for full options list"
            }
          ]
        },
        {
          "id": "manage",
          "title": "Docker CLI",
          "description": "Manage containers",
          "items": [
            {
              "type": "table",
              "rows": [
                {
                  "key": "docker exec CONTAINER CMD",
                  "value": "Run command in container"
                },
                {
                  "key": "docker start [options] CONTAINER",
                  "value": "Start container"
                },
                {
                  "key": "docker stop [options] CONTAINER",
                  "value": "Stop container"
                },
                {
                  "key": "docker kill $ID",
                  "value": "Force stop container"
                },
                {
                  "key": "docker images",
                  "value": "List images"
                },
                {
                  "key": "docker rmi IMAGE",
                  "value": "Delete image"
                }
              ]
            }
          ]
        },
        {
          "id": "cleanup",
          "title": "Docker CLI",
          "description": "Cleanup",
          "items": [
            {
              "type": "code",
              "code": "docker system prune\n# Clean dangling resources\n\ndocker system prune -a\n# Remove all unused images\n\ndocker container prune\n# Remove stopped containers\n\ndocker image prune\n# Remove dangling images\n\ndocker volume prune\n# Remove unused volumes"
            }
          ]
        }
      ]
