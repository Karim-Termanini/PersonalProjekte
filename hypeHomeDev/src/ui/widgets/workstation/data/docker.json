        {
          "id": "build",
          "title": "Service Configuration",
          "description": "Building",
          "items": [
            {
              "type": "code",
              "code": "web:\n  build:\n    context: .\n    args:\n      APP_HOME: app\n    dockerfile: Dockerfile.dev"
            },
            {
              "type": "text",
              "text": "build from Dockerfile"
            },
            {
              "type": "code",
              "code": "image: ubuntu:14.04\nimage: tutum/influxdb"
            },
            {
              "type": "text",
              "text": "build from image"
            }
          ]
        },
        {
          "id": "ports",
          "title": "Service Configuration",
          "description": "Ports & Exposure",
          "items": [
            {
              "type": "code",
              "code": "ports:\n  - \"3000\"\n  - \"8000:80\"\n\nexpose:\n  - \"3000\""
            },
            {
              "type": "text",
              "text": "ports: publish to host   |   expose: only to linked services"
            }
          ]
        },
        {
          "id": "commands",
          "title": "Service Configuration",
          "description": "Commands",
          "items": [
            {
              "type": "code",
              "code": "command: bundle exec thin -p 3000\n\ncommand: [bundle, exec, thin, -p, 3000]\n\nentrypoint: /app/start.sh\nentrypoint: [php, -d, vendor/bin/phpunit]"
            }
          ]
        },
        {
          "id": "environment",
          "title": "Service Configuration",
          "description": "Environment variables",
          "items": [
            {
              "type": "code",
              "code": "environment:\n  RACK_ENV: development\n\nenvironment:\n  - RACK_ENV=development\n\nenv_file: .env\nenv_file: [.env, .development.env]"
            }
          ]
        },
        {
          "id": "dependencies",
          "title": "Service Configuration",
          "description": "Dependencies",
          "items": [
            {
              "type": "code",
              "code": "links:\n  - db:database\n  - redis\n\ndepends_on:\n  - db\n\ndepends_on:\n  db:\n    condition: service_healthy\n  db-init:\n    condition: service_completed_successfully"
            }
          ]
        },
        {
          "id": "other_options",
          "title": "Service Configuration",
          "description": "Other options",
          "items": [
            {
              "type": "code",
              "code": "extends:\n  file: common.yml\n  service: webapp\n\nvolumes:\n  - /var/lib/mysql\n  - ./_data:/var/lib/mysql\n\nrestart: unless-stopped"
            },
            {
              "type": "text",
              "text": "restart: always | on-failure | no (default) | unless-stopped"
            }
          ]
        },
